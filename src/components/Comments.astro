---
// Dual comment system: Cusdis (guest) + Giscus (GitHub) with tab switching
---

<div class="comments-wrapper">
	<div class="comment-tabs">
		<button class="tab-btn active" data-tab="cusdis">游客评论</button>
		<button class="tab-btn" data-tab="giscus">GitHub 评论</button>
	</div>

	<div class="tab-content active" id="tab-cusdis">
		<div id="cusdis_thread"
			data-host="https://cusdis.com"
			data-app-id="6f6ee376-7756-4079-8c13-0603222b62ae"
			data-page-id={Astro.url.pathname}
			data-page-url={Astro.url.href}
			data-page-title={Astro.props.title || ""}
			data-lang="zh-cn"
		></div>
		<script async defer src="https://cusdis.com/js/cusdis.es.js"></script>
	</div>

	<div class="tab-content" id="tab-giscus">
		<div class="giscus"></div>
		<script src="https://giscus.app/client.js"
			data-repo="aimeetyi/cetc3bj"
			data-repo-id="R_kgDOR60GXQ"
			data-category="General"
			data-category-id="DIC_kwDOR60GXc4C7WB6"
			data-mapping="pathname"
			data-strict="0"
			data-reactions-enabled="1"
			data-emit-metadata="0"
			data-input-position="top"
			data-theme="light"
			data-lang="zh-CN"
			crossorigin="anonymous"
			async>
		</script>
	</div>
</div>

<style>
	.comments-wrapper {
		margin-top: 2em;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		overflow: hidden;
	}
	.comment-tabs {
		display: flex;
		border-bottom: 1px solid #e0e0e0;
		background: #f5f5f5;
	}
	.tab-btn {
		flex: 1;
		padding: 12px 16px;
		border: none;
		background: transparent;
		cursor: pointer;
		font-size: 14px;
		color: #666;
		transition: all 0.2s;
	}
	.tab-btn:hover {
		color: #333;
		background: #eee;
	}
	.tab-btn.active {
		color: #2337ff;
		background: white;
		border-bottom: 2px solid #2337ff;
		font-weight: bold;
	}
	.tab-content {
		display: none;
		padding: 1em;
	}
	.tab-content.active {
		display: block;
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const tabs = document.querySelectorAll('.tab-btn');
		const contents = document.querySelectorAll('.tab-content');
		
		tabs.forEach(tab => {
			tab.addEventListener('click', function() {
				const target = this.dataset.tab;
				
				tabs.forEach(t => t.classList.remove('active'));
				contents.forEach(c => c.classList.remove('active'));
				
				this.classList.add('active');
				document.getElementById('tab-' + target).classList.add('active');
			});
		});
	});
</script>
