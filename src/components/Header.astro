---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">新闻动态</HeaderLink>
			<HeaderLink href="/about">案件概述</HeaderLink>
			<HeaderLink href="/products">产品服务</HeaderLink>
			<HeaderLink href="/videos">博客视频</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.xr2robot.com" target="_blank" title="访问主站">
				<span class="sr-only">访问主站</span>
				🏠 主站
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a, h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links, .social-links a {
		display: flex;
		text-decoration: none;
		font-size: 0.9em;
	}
	@media (max-width: 720px) {
		.social-links { display: none; }
		nav { flex-wrap: wrap; }
	}
</style>
